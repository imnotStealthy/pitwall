# Optional — for the STANDALONE server only (npm start / start.bat).
# The overlay app sets these in its Connection settings (no .env needed); the
# app's values override anything here.
# Hosts default to loopback (127.0.0.1). Set UDP_HOST=0.0.0.0 only if the game
# runs on a separate console/PC; that also makes the port reachable from the LAN.
UDP_HOST=127.0.0.1
HTTP_HOST=127.0.0.1
UDP_PORT=20777
HTTP_PORT=9000
LOG_LEVEL=info
